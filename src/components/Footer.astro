---
import Default from '@astrojs/starlight/components/Footer.astro';
import { execSync } from 'node:child_process';

const route = Astro.locals.starlightRoute;
const entry = route?.entry;

const REPO = 'https://github.com/nauticstudios/Documentation';
const year = new Date().getFullYear();

const KNOWN_AUTHORS: Record<string, string> = {
  senkex: 'Senkex',
  ssenkex: 'Senkex',
};

type GitInfo = {
  sha: string;
  short: string;
  name: string;
  email: string;
  date: string;
  handle: string | null;
};

let git: GitInfo | null = null;

if (entry?.filePath) {
  try {
    const out = execSync(
      `git log -1 --format=%H%x1f%an%x1f%ae%x1f%aI -- "${entry.filePath}"`,
      { encoding: 'utf-8' }
    ).trim();

    if (out) {
      const [sha, name, email, iso] = out.split('\x1f');

      let handle: string | null = null;
      const noreply = email.match(/^(?:\d+\+)?([^@]+)@users\.noreply\.github\.com$/);
      if (noreply) {
        handle = noreply[1];
      } else {
        const localPart = email.split('@')[0]?.toLowerCase();
        if (localPart && KNOWN_AUTHORS[localPart]) {
          handle = KNOWN_AUTHORS[localPart];
        } else if (KNOWN_AUTHORS[name.toLowerCase()]) {
          handle = KNOWN_AUTHORS[name.toLowerCase()];
        }
      }

      git = {
        sha,
        short: sha.slice(0, 7),
        name,
        email,
        date: new Date(iso).toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric',
          year: 'numeric',
        }),
        handle,
      };
    }
  } catch {
    /* no git history available */
  }
}

const profileUrl = git?.handle ? `https://github.com/${git.handle}` : null;
const avatarUrl = git?.handle ? `https://github.com/${git.handle}.png?size=48` : null;
const displayName = git?.handle ?? git?.name ?? null;
---

<Default><slot /></Default>

{git && (
  <div class="nautic-git-meta">
    <span>Last updated: {git.date} by</span>
    {profileUrl ? (
      <a href={profileUrl} class="author-link" rel="noopener" target="_blank">
        {avatarUrl && (
          <img
            src={avatarUrl}
            alt=""
            class="avatar"
            loading="lazy"
            width="20"
            height="20"
          />
        )}
        <svg class="gh-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
          <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
        </svg>
        <span class="author-name">{displayName}</span>
      </a>
    ) : (
      <span class="author-name">{displayName}</span>
    )}
    <span>in</span>
    <a href={`${REPO}/commit/${git.sha}`} rel="noopener" target="_blank">
      <code>{git.short}</code>
    </a>
  </div>
)}

<footer class="nautic-legal">
  <p>
    Copyright © {year} <a href="https://nautic-studios.com">Nautic Studios</a>.
    Built with <a href="https://starlight.astro.build" rel="noopener" target="_blank">Starlight</a> &amp;
    <a href="https://astro.build" rel="noopener" target="_blank">Astro</a>.
  </p>
  <p class="disclaimer">
    This website is not an official Minecraft website and is not associated with Mojang Studios or
    Microsoft. All product and company names are trademarks or registered trademarks of their
    respective holders. Use of these names does not imply any affiliation or endorsement by them.
  </p>
</footer>
