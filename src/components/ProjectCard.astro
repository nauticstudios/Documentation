---
interface Link {
  label: string;
  href: string;
  icon?: 'github' | 'docs' | 'external' | 'modrinth' | 'jitpack';
}

interface Tag {
  label: string;
  variant?: 'library' | 'api' | 'experimental' | 'plugin' | 'free' | 'premium';
}

interface Props {
  name: string;
  title: string;
  description: string;
  banner?: string;
  logo?: string;
  accent?: string;
  tags?: Tag[];
  links?: Link[];
}

const {
  name,
  title,
  description,
  banner,
  logo,
  accent = '#3b82f6',
  tags = [],
  links = [],
} = Astro.props;

const iconPaths: Record<string, string> = {
  github:
    'M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.92.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.52-1.32-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.35.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.19-1.49 3.15-1.18 3.15-1.18.62 1.59.23 2.76.11 3.05.73.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.42.36.79 1.07.79 2.16v3.2c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z',
  docs: 'M4 4h12a2 2 0 0 1 2 2v14l-4-2-4 2-4-2-4 2V6a2 2 0 0 1 2-2z',
  external: 'M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3zM5 5h6v2H7v10h10v-4h2v6H5V5z',
  modrinth:
    'M12 2a10 10 0 1 0 10 10h-2a8 8 0 1 1-2.34-5.66l1.41-1.41A10 10 0 0 0 12 2zm5 8v2h5v-2h-5z',
  jitpack: 'M3 3h18v6h-2V5H5v14h6v2H3V3zm10 10h8v8h-8v-8z',
};
---

<article class="project-card" style={`--accent: ${accent};`}>
  <div class="project-card__media">
    {banner ? (
      <img src={banner} alt={`${title} banner`} class="project-card__banner" loading="lazy" />
    ) : (
      <div class="project-card__banner project-card__banner--fallback">
        <span>{name}</span>
      </div>
    )}
    {logo && <img src={logo} alt={`${title} logo`} class="project-card__logo" loading="lazy" />}
  </div>

  <div class="project-card__body">
    <h3 class="project-card__title">{title}</h3>
    <p class="project-card__desc">{description}</p>

    {tags.length > 0 && (
      <div class="project-card__tags">
        {tags.map((t) => (
          <span class={`project-tag project-tag--${t.variant ?? 'plugin'}`}>{t.label}</span>
        ))}
      </div>
    )}

    {links.length > 0 && (
      <div class="project-card__links">
        {links.map((l) => (
          <a class="project-link" href={l.href} target="_blank" rel="noopener">
            {l.icon && iconPaths[l.icon] && (
              <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                <path fill="currentColor" d={iconPaths[l.icon]} />
              </svg>
            )}
            <span>{l.label}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</article>
